@inject GoodHamburger.Presentation.Services.ToastService ToastService
@implements IDisposable

<div class="toast-container">
    @foreach (var toast in toasts)
    {
        <div class="toast-box @toast.Type.ToString().ToLower()">
            @toast.Message
        </div>
    }
</div>

@code {
    private List<ToastItem> toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private async void ShowToast(string msg, ToastType type)
    {
        var toast = new ToastItem(msg, type);

        toasts.Add(toast);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(3000);

        toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }

    private record ToastItem(string Message, ToastType Type);
}